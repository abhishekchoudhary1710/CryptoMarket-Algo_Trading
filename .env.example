# Exchange Configuration
EXCHANGE_ID=bybit                    # binance, bybit, okx, etc.
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_PASSWORD=                   # only needed for some exchanges (e.g. okx)
EXCHANGE_SANDBOX=true                # set to false for live trading

# Trading pair and timeframe
SYMBOL=XAU_USD
TRADE_SYMBOL_LOCK=XAUUSD
TIMEFRAME=5m
LOOP_SLEEP_SECONDS=2
TICK_LOG_INTERVAL_SECONDS=15        # set 0 to disable heartbeat logs

# Divergence strategy (two-chart setup)
DIVERGENCE_PRIMARY_SYMBOL=XAU_USD
DIVERGENCE_SECONDARY_SYMBOL=MCX:GOLD_FUT
DIVERGENCE_PRIMARY_LABEL=XAUUSD
DIVERGENCE_SECONDARY_LABEL=GOLD_MCX_FUT
DIVERGENCE_THRESHOLD_MINUTES=15
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=23
MARKET_CLOSE_MINUTE=30

# Risk Management
RISK_PER_TRADE_PCT=0.5
MAX_DAILY_LOSS_PCT=2.0
MAX_SPREAD_PCT=0.15

# Divergence position sizing defaults
LOT_SIZE=1
MAX_LOTS=10
TARGET_RISK_MIN=500
TARGET_RISK_MID=1000
TARGET_RISK_MAX=1500
DEFAULT_LOT_SIZE=1
MAX_REQUESTS_PER_MINUTE=500
MIN_REQUEST_INTERVAL_MS=50

# Angel One / MCX integration (for GOLD MCX futures ticks)
ANGEL_API_KEY=
ANGEL_USERNAME=
ANGEL_PASSWORD=
ANGEL_TOTP_KEY=
ANGEL_SCRIPMASTER_URL=https://margincalculator.angelbroking.com/OpenAPI_File/files/OpenAPIScripMaster.json
MCX_EXCHANGE_SEGMENT=MCX
MCX_INSTRUMENT_TYPE=FUTCOM
MCX_NAME=GOLD
MCX_TRADINGSYMBOL_CONTAINS=GOLD
MCX_EXCLUDE_KEYWORDS=MINI,PETAL
MCX_WS_EXCHANGE_TYPE=5


# Dual-feed pipeline (XAUUSD + MCX GOLD FUTURES)
PRIMARY_PROVIDER=oanda
PRIMARY_SYMBOL=XAU_USD
PRIMARY_TICK_POLL_SECONDS=1
CANDLE_TIMEFRAMES_MINUTES=1,3,5,10,15
DIVERGENCE_TIMEFRAME_MINUTES=10
ENTRY_TIMEFRAME_MINUTES=3
DUAL_FEED_HEARTBEAT_SECONDS=15
SIGNAL_JOURNAL_PATH=logs/signal_journal.csv
SIGNAL_MAX_AGE_MINUTES=90
STALE_FEED_WARN_SECONDS=20

# OANDA primary feed (paper/demo path)
OANDA_ENV=practice
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_INSTRUMENT=XAU_USD
OANDA_REQUEST_TIMEOUT_SECONDS=10

# Strategy
BARS_TO_LOAD=500
ENTRY_BUFFER_PCT=0.01
RR_RATIO=2.0
